{
  "name": "@daciasec/niko-cli",
  "version": "0.1.0",
  "description": "Developer ops toolkit - git commits, shell config, AI integration, and more",
  "main": "dist/index.js",
  "bin": {
    "niko": "bin/niko"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "prepare": "npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "cli",
    "developer-tools",
    "git",
    "ops",
    "automation",
    "shell",
    "bash",
    "zsh",
    "ai",
    "openai",
    "claude",
    "commit"
  ],
  "author": "DaciaSec",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daciasec/niko-cli.git"
  },
  "bugs": {
    "url": "https://github.com/daciasec/niko-cli/issues"
  },
  "homepage": "https://github.com/daciasec/niko-cli#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.0",
    "simple-git": "^3.22.0",
    "execa": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/inquirer": "^9.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
}